---
import BaseLayout from '../layouts/BaseLayout.astro';

const pageTitle = "About Me";

const identity = {
    firstName: "Tarun",
    country: "Unknown",
    occupation: "Student",
    hobbies: ["Karting", "Bowling", "8-BallPool", "Rock Climbing"],
    role: "Network Engineering",
    certificates: "CCNA [YET TO PASS]",
}

const skills = ["HTML", "CSS", "JavaScript", "React", "Astro", "Node Js", "Bun", "Express", "C++", "C", "Python", "Full Stack", "Networking"];

const happy = true;
const goal = false;
---

<BaseLayout pageTitle={pageTitle}>
    <div style="border: 2px solid #39ff14; padding: 1.5rem; margin: 2rem 0; background-color: rgba(57, 255, 20, 0.05);">
        <h2 style="margin-top: 0;">[ PROFILE LOADED ]</h2>
        <p style="color: #e0e0e0;">I am a digital craftsperson exploring the intersection of code and creativity through Astro and modern web technologies.</p>
    </div>

    <h3 style="color: #00ffff; margin-top: 2rem;">[ CORE ATTRIBUTES ]</h3>
    <ul style="color: #e0e0e0; list-style: none; padding-left: 1rem; border-left: 2px solid #00ffff;">
        <li style="padding: 0.5rem 0;"><span style="color: #39ff14;">Name:</span> {identity.firstName}</li>
        <li style="padding: 0.5rem 0;"><span style="color: #39ff14;">Location:</span> {identity.country}</li>
        <li style="padding: 0.5rem 0;"><span style="color: #39ff14;">Occupation:</span> {identity.occupation}</li>
        {identity.hobbies.length >= 2 && 
        <li style="padding: 0.5rem 0;"><span style="color: #39ff14;">Hobbies:</span> {identity.hobbies[0]}, {identity.hobbies[1]}, {identity.hobbies[2]}, {identity.hobbies[3]}</li>
        }
        <li style="padding: 0.5rem 0;"><span style="color: #39ff14;">Aiming For:</span> {identity.role}</li>
        <li style="padding: 0.5rem 0;"><span style="color: #39ff14;">Certficates:</span> {identity.certificates}</li>
    </ul>

    <h3 style="color: #00ffff; margin-top: 2rem;">[ SKILLS MATRIX ]</h3>
    <ul style="list-style: none; padding: 0; margin: 1rem 0;">
        {skills.map ((skill) => <li style="padding: 0.5rem; margin: 0.5rem 0; border: 1px solid #39ff14; color: #39ff14; background-color: rgba(57, 255, 20, 0.05); border-radius: 3px; display: inline-block; margin-right: 0.5rem;">{skill}</li>)}
    </ul>

    <h3 style="color: #00ffff; margin-top: 2rem;">[ STATUS ]</h3>
    {happy && <p style="color: #39ff14;">✓ System operational and excited to explore new frontiers.</p>}
    {goal ? <p style="color: #00ffff;">⟐ Objective Complete: CCNA Passed!</p> : <p style="color: #00ffff;">⟐ Current Objective: CCNA Preparation.</p>}
</BaseLayout>
