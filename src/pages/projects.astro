---
import BaseLayout from "../layouts/BaseLayout.astro";
const pageTitle = "Projects";
---

<BaseLayout pageTitle={pageTitle}>
    <div style="border: 1px solid #00ffff; padding: 1rem; margin: 1.5rem 0; background-color: rgba(0, 255, 255, 0.03);">
        <p style="color: #999999; margin: 0;">[ PROJECT ARCHIVE INITIALIZED ]</p>
        <p style="color: #e0e0e0; margin: 0.5rem 0 0 0;">Detailed project portfolio coming soon. Check back for technical implementations and digital creations.</p>
    </div>

    <div style="border: 2px solid #39ff14; padding: 1.5rem; margin: 2rem 0; background-color: rgba(57, 255, 20, 0.05); text-align: center;">
        <p style="color: #39ff14; font-size: 1.1rem; margin: 0;">[ LOADING PROJECTS... ]</p>
        <p style="color: #999999; margin: 1rem 0 0 0; font-style: italic;">Catalog expansion in progress</p>
    </div>
</BaseLayout>
