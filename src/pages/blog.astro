---
import BaseLayout from "../layouts/BaseLayout.astro"
import BlogPost from "../components/BlogPost.astro";

const allPostsData = Object.values(import.meta.glob('./posts/*.md', { eager: true }));
const pageTitle = "Blogs"
---
<BaseLayout pageTitle={pageTitle}>
    <div style="border: 1px solid #00ffff; padding: 1rem; margin: 1.5rem 0; background-color: rgba(0, 255, 255, 0.03);">
        <p style="color: #999999; margin: 0;">[ ACCESSING BLOG DATABASE ]</p>
        <p style="color: #e0e0e0; margin: 0.5rem 0 0 0;">Journey through my technical chronicles and learnings.</p>
    </div>

    <ul style="list-style: none; padding: 0; margin: 2rem 0;">
        {allPostsData.map((post:any) => <BlogPost url={post.url} title={post.frontmatter.title} />)}
    </ul>
</BaseLayout>