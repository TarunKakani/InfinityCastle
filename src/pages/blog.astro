---
import BaseLayout from "../layouts/BaseLayout.astro"
import BlogPost from "../components/BlogPost.astro";

// access all data from our posts at once through - import.meta.glob()
const allPostsData = Object.values(import.meta.glob('./posts/*.md', { eager: true }));
const pageTitle = "Blogs"
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>{pageTitle}</title>
	</head>
	<body>
        <BaseLayout pageTitle={pageTitle}>
			<p>This is where I will post about my journey learning Astro.</p>

			<!-- allPostsData is generating the list of posts dynamically so we dont have to route it manually -->
			<ul>
				{allPostsData.map((post:any) => <BlogPost url={post.url} title={post.frontmatter.title} />)}
			</ul>
		</BaseLayout>
	</body>
</html>