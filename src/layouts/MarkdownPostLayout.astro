---
import BaseLayout from "./BaseLayout.astro";
const { frontmatter } = Astro.props;
---

<BaseLayout pageTitle={frontmatter.title}>
    <div class="card">
        <p><span style="color: #00ffff;">[author]</span> {frontmatter.author}</p>
        <p><span style="color: #00ffff;">[published]</span> {frontmatter.pubDate.toString().slice(0,10)}</p>
        <img src={frontmatter.image.url} width="300" alt={frontmatter.image.alt} style="border: 1px solid #00ffff; margin: 1rem 0;" />
    </div>
    <article class="card">
        <slot />
    </article>
</BaseLayout>
